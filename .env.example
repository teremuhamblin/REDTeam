# REDTeam environment example
# Copy to .env and fill with real values for local lab only.

# General
RTOPS_ENV=lab
LOG_LEVEL=INFO

# Paths
WORK_DIR=/tmp/redteam_workdir
REPORTS_DIR=./reports

# Network / lab config
LAB_DOMAIN=lab.local
LAB_C2_HOST=127.0.0.1
LAB_C2_PORT=8080

# API keys (use vault/CI secrets in production)
# EXAMPLE_API_KEY=changeme

# Email simulation (for phishing_sim)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Safety toggles
ALLOW_NETWORK_OPERATIONS=false
ANONYMIZE_OUTPUT=true
